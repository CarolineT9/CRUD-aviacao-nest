generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Piloto {
  id         Int     @id @default(autoincrement())
  nome       String
  matricula  String  @unique
  isAtivo    Boolean @default(true)
}

model Aeronave {
  id                  Int    @id @default(autoincrement())
  prefixo             String
  autonomia           Int
  velocidadeCruzeiro  Float
}